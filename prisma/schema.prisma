// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String
  name          String
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  links         ShortLink[]
  @@map("users")
}
model ShortLink {
  id           String    @id @default(cuid())
  originalUrl  String    @unique @map("original_url") 
  shortCode    String    @unique @map("short_code")
  secretToken   String           @map("secret_token")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  goLiveAt     DateTime? @map("go_live_at")
  expiresAt    DateTime? @map("expires_at")
  clickCap     Int?      @map("click_cap")
  waitlistUrl  String?   @map("waitlist_url")
  currentClicks Int      @default(0) @map("current_clicks")
  version       Int      @default(0)
  analytics    ClickAnalytics[]
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shortCode])
  @@map("short_links")
}


/// Event Log Model storing immutable individual click entries for time-series charts.
model ClickAnalytics {
  id        String   @id @default(cuid())
  linkId    String   @map("link_id")
  timestamp DateTime @default(now())

  //Smart Analytics Categorisation
  isUnique  Boolean  @default(false) @map("is_unique")
  referrer  String   @default("Direct")               
  device    String   @default("Unknown")              
  browser   String   @default("Unknown")              
  
  // Geolocational Mapping
  country   String   @default("Unknown")              
  region    String   @default("Unknown")              

  //Bot / Filter Engineering Flags
  isBot     Boolean  @default(false) @map("is_bot")   

  // Relations
  shortLink ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  // Compound index ensures ultra-fast time-series metrics extraction under heavy scale
  @@index([linkId, timestamp])
  @@map("click_analytics")
}
